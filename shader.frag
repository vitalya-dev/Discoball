#version 330 core

// Входящие данные из вершинного шейдера
in vec3 v_position;
in vec3 v_normal;

// Итоговый цвет пикселя на экране
out vec4 f_color;

void main() {
    // Нормализуем вектор направления поверхности (чтобы его длина была равна 1)
    vec3 N = normalize(v_normal);
    
    // Задаем позицию виртуального источника света (софита)
    vec3 light_pos = vec3(5.0, 5.0, 5.0);
    vec3 L = normalize(light_pos - v_position);
    
    // Направление взгляда (предполагаем, что смотрим из центра в сторону шара)
    vec3 V = normalize(-v_position); 
    
    // --- Эффект маленьких зеркал ---
    // Умножаем координаты и берем дробную часть, чтобы создать повторяющуюся сетку
    float tiles = 20.0; 
    vec3 tile_uv = fract(N * tiles);
    
    // Делаем темные "швы" между зеркальцами
    float border = 0.1; 
    float is_border = step(1.0 - border, tile_uv.x) + step(1.0 - border, tile_uv.y) + step(1.0 - border, tile_uv.z);
    is_border = clamp(is_border, 0.0, 1.0);
    
    // --- Освещение ---
    // Вычисляем, как свет отражается от поверхности
    vec3 R = reflect(-L, N);
    
    // Базовый свет (насколько поверхность освещена прямым светом)
    float diff = max(dot(N, L), 0.0);
    
    // Яркий блик. Степень 128.0 делает блик маленьким и очень резким (как на стекле или зеркале)
    float spec = pow(max(dot(V, R), 0.0), 128.0);
    
    // Задаем базовый серебристо-голубоватый цвет зеркала
    vec3 mirror_color = vec3(0.8, 0.85, 0.9);
    
    // Смешиваем цвет освещенного зеркала с темным цветом швов
    vec3 final_color = mix(mirror_color * diff, vec3(0.05), is_border);
    
    // Добавляем к итоговому цвету наш яркий белый блик
    final_color += vec3(spec);
    
    // Отправляем цвет на экран (последняя цифра 1.0 означает полную непрозрачность)
    f_color = vec4(final_color, 1.0);
}